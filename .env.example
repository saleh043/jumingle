# =====================================================================
# JUMINGLE - environment variables
# Copy this file to ".env" for local development, or set these in your
# host's dashboard (Render, etc.) for production. Nothing here is secret
# by default - CHANGE the password and salt before going live.
# =====================================================================

# --- Core ---
NODE_ENV=development
PORT=3000
# Set to true when running behind a proxy/load balancer (Render, Nginx).
TRUST_PROXY=true

# --- Admin panel ---
# CHANGE THIS to a long, random password.
ADMIN_PASSWORD=changeme123

# --- Security ---
# Random salt used to hash IP addresses (we never store raw IPs).
# CHANGE THIS to a long random string and keep it stable.
IP_HASH_SALT=please-change-this-to-a-long-random-string
# Turn the whole site into a "we'll be back" page.
MAINTENANCE_MODE=false

# --- Bans ---
DEFAULT_BAN_HOURS=24

# --- Matchmaking / sessions ---
# How long (ms) a dropped user can reconnect and resume the same chat.
SESSION_RECOVERY_MS=30000
MAX_INTERESTS=5

# --- Chat limits / anti-abuse ---
MAX_MESSAGE_LENGTH=1000
MSG_RATE_MAX=8
MSG_RATE_WINDOW_MS=10000
FIND_RATE_MAX=30
FIND_RATE_WINDOW_MS=10000
REPORT_LOG_SIZE=10

# --- WebRTC ICE servers ---
# One or more STUN urls, comma separated.
STUN_URLS=stun:stun.l.google.com:19302
# TURN is needed for users on strict networks. Leave blank to disable.
# Example: turn:turn.example.com:3478,turns:turn.example.com:5349
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# --- Front-end links / content ---
DISCORD_URL=#
CONTACT_EMAIL=support@example.com
